[sqlfluff]
dialect = duckdb
# 140 (was 120): the analytics SQL legitimately has long variance/stddev
# aggregates (e.g. ROUND(SQRT(AVG(x*x) - AVG(x)*AVG(x)), ...)) that are more
# readable on one line than awkwardly wrapped. 140 keeps a sensible ceiling
# without forcing unreadable mid-expression breaks.
max_line_length = 140
# Excluded rules, with rationale (these are either high-risk to auto-fix or
# low-value noise for this analytics-SQL repo):
#   LT01, LT02, AL04 — pre-existing exclusions (whitespace / comma style).
#   AL03, AL10       — column/derived-table aliasing; fixing means naming ~50
#                      computed columns, high churn for no behavior change.
#   RF02             — GROUP BY references a select alias; DuckDB supports this
#                      (it's the whole point of the alias), so the rule is a
#                      false positive for this dialect.
#   RF04             — flags `date` (and a few others) as keyword identifiers;
#                      renaming would cascade into Python + dbt downstream.
#   AM04, AM05       — unknown result columns / unqualified joins; these
#                      analytics queries are intentionally exploratory.
#   ST03, ST05, ST09 — join-ordering / wildcard-position structure rules;
#                      subjective and not worth the reordering churn here.
exclude_rules = LT01,LT02,AL04,AL03,AL10,RF02,RF04,AM04,AM05,ST03,ST05,ST09


[sqlfluff:indentation]
tab_width = 4

[sqlfluff:rules:layout.long_lines]
ignore_comment_lines = True
ignore_comment_clauses = True
